# WebSocket URL of the ZeroSync server.
# Copy this file to .env and set the value for your deployment.
# Default (local dev): ws://localhost:8080/ws
VITE_SERVER_URL=wss://api.example.com/ws

# Deployment context — affects user-facing copy when the server is unreachable.
# 'self-hosted' (default): assumes the user runs the server, mentions `docker compose up`
# 'public':                public demo — neutral message with self-host link
VITE_DEMO_MODE=self-hosted
