---
/**
 * Hero.astro — above-the-fold headline, sub-pitch, CTAs, architecture diagram.
 */

const base = import.meta.env.BASE_URL
---

<section id="hero" class="relative min-h-screen flex items-center px-6 py-24 overflow-hidden">
  {/* Interactive connected-nodes background (cursor repels, graph springs back) */}
  <canvas id="hero-bg" class="hero-bg absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></canvas>

  <div class="relative max-w-5xl mx-auto w-full">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-neutral-100 mb-6 max-w-4xl">
      End-to-end encrypted
      <br class="hidden sm:block" />
      real-time collaboration SDK.
    </h1>

    <p class="text-xl sm:text-2xl text-neutral-400 mb-6 font-medium">
      Self-hosted in one Docker command.
    </p>

    <p class="text-base sm:text-lg text-neutral-400 mb-10 max-w-2xl leading-relaxed">
      Add Google Docs-style multi-user editing, presence, and chat to any web app —
      where your server mathematically cannot read plaintext. Built on WebRTC, Yjs, and
      AES-256-GCM via the browser's native Web Crypto API.
    </p>

    <div class="flex flex-wrap gap-3 mb-6">
      <a
        href={`${base}demo/`}
        class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-lg border border-accent/40 bg-accent/10 text-accent font-mono font-semibold text-base hover:border-accent hover:bg-accent/15 transition-colors"
      >
        ▶ Try the live demo
      </a>
      <a
        href="#pricing"
        class="inline-flex items-center px-6 py-3 rounded-lg border border-neutral-700 text-neutral-200 hover:border-accent hover:text-accent"
      >
        View pricing
      </a>
      <a
        href="https://github.com/tovsa7/ZeroSync"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-neutral-700 text-neutral-200 hover:border-accent hover:text-accent"
      >
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 00-3.8 23.4c.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0C17.3 4.7 18.3 5 18.3 5c.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0012 .3"/></svg>
        GitHub
      </a>
    </div>

    <p class="text-xs text-neutral-500 font-mono">
      MIT client · BSL 1.1 server · Self-hosted in one Docker command
    </p>
  </div>
</section>

<style>
  /* Fade the canvas where the hero text sits so nodes don't compete with reading */
  .hero-bg {
    -webkit-mask-image: radial-gradient(
      ellipse 55% 40% at 35% 50%,
      transparent 5%,
      rgba(0, 0, 0, 0.25) 42%,
      rgba(0, 0, 0, 0.75) 70%,
      #000 100%
    );
    mask-image: radial-gradient(
      ellipse 55% 40% at 35% 50%,
      transparent 5%,
      rgba(0, 0, 0, 0.25) 42%,
      rgba(0, 0, 0, 0.75) 70%,
      #000 100%
    );
  }

  @media (max-width: 640px) {
    .hero-bg {
      -webkit-mask-image: radial-gradient(
        ellipse 80% 55% at 50% 50%,
        transparent 5%,
        rgba(0, 0, 0, 0.25) 45%,
        rgba(0, 0, 0, 0.75) 75%,
        #000 100%
      );
      mask-image: radial-gradient(
        ellipse 80% 55% at 50% 50%,
        transparent 5%,
        rgba(0, 0, 0, 0.25) 45%,
        rgba(0, 0, 0, 0.75) 75%,
        #000 100%
      );
    }
  }
</style>

<script is:inline>
  (function () {
    const canvas = document.getElementById('hero-bg')
    if (!canvas) return
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    const ctx     = canvas.getContext('2d')
    const section = canvas.parentElement
    const TEAL    = '94, 234, 212'

    const MAX_DIST     = 170
    const REPEL_RADIUS = 180
    const REPEL_FORCE  = 0.55
    const HOME_SPRING  = 0.012
    const DAMPING      = 0.945

    let W = 0, H = 0, nodes = [], active = true
    const mouse = { x: -9999, y: -9999 }

    function resize() {
      W = canvas.width  = canvas.offsetWidth
      H = canvas.height = canvas.offsetHeight
    }
    function rebuild() {
      nodes = []
      // Density scales with viewport — phone ~95, desktop ~160+
      const count = Math.max(60, Math.min(200, Math.round(Math.sqrt(W * H) * 0.17)))
      for (let i = 0; i < count; i++) {
        const x = Math.random() * W
        const y = Math.random() * H
        nodes.push({
          x, y, hx: x, hy: y,
          vx: 0, vy: 0,
          phase:  Math.random() * Math.PI * 2,
          speedA: 0.0007 + Math.random() * 0.0008,
          speedB: 0.0009 + Math.random() * 0.001,
          ampA:   0.6   + Math.random() * 0.7,
          ampB:   0.5   + Math.random() * 0.6,
        })
      }
    }

    section.addEventListener('mousemove', (e) => {
      const r = canvas.getBoundingClientRect()
      mouse.x = e.clientX - r.left
      mouse.y = e.clientY - r.top
    })
    section.addEventListener('mouseleave', () => { mouse.x = mouse.y = -9999 })

    new IntersectionObserver(([e]) => { active = e.isIntersecting }, { threshold: 0 }).observe(canvas)
    window.addEventListener('resize', () => { resize(); rebuild() })

    resize(); rebuild()

    function tick(now) {
      if (active) {
        const t = now
        ctx.clearRect(0, 0, W, H)

        for (const n of nodes) {
          const dx = n.x - mouse.x, dy = n.y - mouse.y
          const d  = Math.hypot(dx, dy)
          if (d < REPEL_RADIUS && d > 0) {
            const k = 1 - d / REPEL_RADIUS
            const f = k * k * REPEL_FORCE
            n.vx += (dx / d) * f
            n.vy += (dy / d) * f
          }
          n.vx += (n.hx - n.x) * HOME_SPRING
          n.vy += (n.hy - n.y) * HOME_SPRING
          n.vx += Math.sin(t * n.speedA + n.phase)       * n.ampA * 0.04
          n.vy += Math.cos(t * n.speedB + n.phase * 1.3) * n.ampB * 0.04
          n.vx *= DAMPING
          n.vy *= DAMPING
          n.x  += n.vx
          n.y  += n.vy
        }

        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i], b = nodes[j]
            const d = Math.hypot(a.x - b.x, a.y - b.y)
            if (d < MAX_DIST) {
              const k = 1 - d / MAX_DIST
              ctx.strokeStyle = 'rgba(' + TEAL + ', ' + (k * k * 0.55) + ')'
              ctx.lineWidth   = 0.8
              ctx.beginPath()
              ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y)
              ctx.stroke()
            }
          }
        }
        for (const n of nodes) {
          ctx.fillStyle = 'rgba(' + TEAL + ', 0.82)'
          ctx.beginPath()
          ctx.arc(n.x, n.y, 1.8, 0, Math.PI * 2)
          ctx.fill()
        }
      }
      requestAnimationFrame(tick)
    }
    requestAnimationFrame(tick)
  })()
</script>
