---
/**
 * Pricing.astro — 4 self-serve tier cards + Enterprise contact-sales banner.
 *
 * Pivot 2026-04-29: priced by team size, not by rooms/peers.
 * Limits removed — they conflicted with the privacy positioning
 * (charging more to protect more users is an anti-incentive).
 */

interface Tier {
  name:      string
  priceMo:   string | null
  priceYr:   string
  yrNote:    string | null
  audience:  string  // who this tier is for, e.g. "companies up to 10 people"
  features:  string[]
  cta:       { text: string; href: string }
  popular?:  boolean
}

// Single universal Tally form (form id `ob0M4M`) — collects email, company,
// team size, industry, self-hosted readiness, use case. Replaces the prior
// per-tier mailto: handoff so all paid-tier interest funnels through one
// inbox with structured data.
const TALLY_REQUEST_ACCESS = 'https://tally.so/r/ob0M4M'

const tiers: Tier[] = [
  {
    name:     'Community',
    priceMo:  null,
    priceYr:  'Free',
    yrNote:   null,
    audience: 'Non-production · OSS · evaluation',
    features: [
      'Full SDK + signaling server',
      'All cryptographic features',
      'Self-hosted, Docker-deployable',
      'GitHub Discussions support',
    ],
    cta: { text: 'Get started', href: 'https://github.com/tovsa7/ZeroSync' },
  },
  {
    name:     'Startup',
    priceMo:  '$99',
    priceYr:  '$990/yr',
    yrNote:   '2 months free',
    audience: 'Companies up to 10 people',
    features: [
      'Production license',
      'Email support',
      'Annual or monthly billing',
      'Grandfathered pricing as you grow',
    ],
    cta: { text: 'Request access', href: TALLY_REQUEST_ACCESS },
  },
  {
    name:     'Team',
    priceMo:  '$399',
    priceYr:  '$3,990/yr',
    yrNote:   '2 months free',
    audience: 'Companies up to 50 people',
    features: [
      'Production license',
      'Priority email support',
      'Compliance documentation pack',
      'Direct Slack / email channel',
    ],
    cta: { text: 'Request access', href: TALLY_REQUEST_ACCESS },
    popular: true,
  },
  {
    name:     'Business',
    priceMo:  '$1,499',
    priceYr:  '$14,990/yr',
    yrNote:   '2 months free',
    audience: 'Companies 50+ people',
    features: [
      'Everything in Team',
      'BAA discussion (HIPAA workflows)',
      'DPA template included',
      'Quarterly review with the author',
    ],
    cta: { text: 'Request access', href: TALLY_REQUEST_ACCESS },
  },
]
---

<section class="ambient-glow px-6 py-24 border-t border-neutral-900" id="pricing">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-neutral-100 mb-4">
      Pricing
    </h2>
    <p class="text-neutral-400 mb-12 max-w-2xl">
      Open-core: client SDK is MIT, signaling server is BSL 1.1 (free for dev/test,
      paid in production). Priced by team size — no per-room or per-peer limits.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {tiers.map((tier) => {
        const tallyMatch = tier.cta.href.match(/tally\.so\/r\/([A-Za-z0-9]+)/)
        const tallyId    = tallyMatch ? tallyMatch[1] : null
        return (
        <article
          class:list={[
            'relative flex flex-col p-6 rounded-xl border transition-colors',
            tier.popular
              ? 'conic-border card-premium-gradient border-accent ring-1 ring-accent/20'
              : 'border-neutral-800 bg-neutral-900/40 hover:border-neutral-700',
          ]}
        >
          {tier.popular && (
            <span class="absolute -top-3 left-6 px-2.5 py-0.5 rounded-full bg-accent text-neutral-950 text-xs font-semibold">
              Most popular
            </span>
          )}

          <h3 class="text-lg font-semibold text-neutral-100 mb-1">{tier.name}</h3>
          <p class="text-xs text-neutral-500 mb-4 min-h-[2.5rem]">{tier.audience}</p>

          <div class="mb-5 min-h-[3.5rem]">
            {tier.priceMo ? (
              <>
                <span class="text-3xl font-bold text-neutral-100">{tier.priceMo}</span>
                <span class="text-sm text-neutral-500">/mo</span>
                <div class="text-xs text-neutral-500 mt-1">
                  or <span class="text-neutral-400">{tier.priceYr}</span>
                  {tier.yrNote && <span class="text-accent"> · {tier.yrNote}</span>}
                </div>
              </>
            ) : (
              <>
                <span class="text-3xl font-bold text-neutral-100">{tier.priceYr}</span>
                {tier.yrNote && <div class="text-xs text-neutral-500 mt-1">{tier.yrNote}</div>}
              </>
            )}
          </div>

          <ul class="flex-1 space-y-2 text-sm text-neutral-300 mb-6">
            {tier.features.map((f) => (
              <li class="flex gap-2 items-start">
                <svg aria-hidden="true" class="shrink-0 size-4 mt-0.5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <a
            href={tier.cta.href}
            target={tier.cta.href.startsWith('http') && !tallyId ? '_blank' : undefined}
            rel={tier.cta.href.startsWith('http') && !tallyId ? 'noopener' : undefined}
            data-tally-open={tallyId ?? undefined}
            data-tally-layout={tallyId ? 'modal' : undefined}
            data-tally-width={tallyId ? '600' : undefined}
            class:list={[
              'block text-center px-4 py-2.5 rounded-lg font-medium text-sm',
              tier.popular
                ? 'bg-accent text-neutral-950 hover:bg-accent-muted hover:text-neutral-950'
                : 'border border-neutral-700 text-neutral-200 hover:border-accent hover:text-accent',
            ]}
          >
            {tier.cta.text}
          </a>
          {tier.cta.href.startsWith('mailto:') && (
            <p class="mt-2 text-center text-xs text-neutral-500 font-mono select-all">
              contact.zerosync@proton.me
            </p>
          )}
        </article>
        )
      })}
    </div>

    {/* Enterprise — contact-sales banner below the self-serve grid */}
    <article class="mt-6 p-6 rounded-xl border border-neutral-800 bg-neutral-900/30 hover:border-neutral-700 transition-colors flex flex-col md:flex-row md:items-center gap-5">
      <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
          <h3 class="text-lg font-semibold text-neutral-100">Enterprise</h3>
          <span class="text-xs text-neutral-500">Talk to us</span>
        </div>
        <p class="text-sm text-neutral-400 leading-relaxed max-w-3xl">
          Custom contracts, signed BAA / DPA, priority on the roadmap, and a
          quarterly sync with the author. Designed for HIPAA / privileged-legal
          / fintech / regulated-EU SaaS engagements where procurement requires
          line-item negotiation and security review.
        </p>
      </div>
      <a
        href="mailto:contact.zerosync@proton.me?subject=ZeroSync%20Enterprise%20inquiry"
        class="shrink-0 inline-flex items-center justify-center px-5 py-3 rounded-lg bg-accent text-neutral-950 font-semibold hover:bg-accent-muted hover:text-neutral-950"
      >
        Email contact.zerosync@proton.me
      </a>
    </article>

    <p class="mt-10 text-sm text-neutral-500 max-w-3xl">
      Self-hosted only — no managed cloud (by design — the server sees only
      ciphertext, so a managed cloud wouldn't add value over your own).
      Headcount tiers are honor-system with the standard B2B audit clause; we
      can't count your team without breaking the privacy story.
    </p>

    <p class="mt-4 text-sm text-neutral-500 max-w-3xl">
      Need higher limits, custom SLA, or a signed DPA / BAA?
      {' '}<a href="mailto:contact.zerosync@proton.me?subject=Custom%20terms%20inquiry" class="text-accent hover:underline">Email contact.zerosync@proton.me</a> — you'll reach the author directly.
    </p>
  </div>
</section>
