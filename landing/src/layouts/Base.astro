---
/**
 * Base.astro — shared <html> scaffold for all pages.
 *
 * Provides:
 * - SEO meta tags (title, description, OG, Twitter card, JSON-LD)
 * - Favicon + font loading
 * - Global stylesheet
 * - Body container
 */

import '../styles/global.css'

interface Props {
  title?:       string
  description?: string
  canonical?:   string
}

const {
  title       = 'ZeroSync — End-to-end encrypted real-time collaboration SDK',
  description = 'Add Google Docs-style multi-user editing to any web app where the server mathematically cannot read plaintext. Self-hosted in one Docker command. HIPAA, GDPR, attorney-client privilege by architecture.',
  canonical,
} = Astro.props

const siteUrl = 'https://tovsa7.github.io/ZeroSync/'
const canonicalUrl = canonical ?? siteUrl
const ogImage = new URL('og-image.png', Astro.site + Astro.url.pathname).href
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Favicon */}
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    {/* Scroll-reveal: mark <html> before paint so initial-hidden CSS applies
        without flash. Without JS → class never added → content visible by default. */}
    <script is:inline>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('js-reveal')
      }
    </script>
    <style is:global>
      html.js-reveal section .grid > *,
      html.js-reveal section details,
      html.js-reveal section > div > article {
        opacity: 0;
        transform: translateY(14px);
        transition: opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
                    transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
      }
      html.js-reveal section .grid > .revealed,
      html.js-reveal section details.revealed,
      html.js-reveal section > div > article.revealed {
        opacity: 1;
        transform: translateY(0);
      }
    </style>

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="ZeroSync" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Tally embed — opens forms in modal on click */}
    <script async src="https://tally.so/widgets/embed.js"></script>

    {/* JSON-LD — SoftwareApplication schema */}
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context':        'https://schema.org',
      '@type':           'SoftwareApplication',
      name:              'ZeroSync',
      description,
      applicationCategory: 'DeveloperApplication',
      operatingSystem:   'Web, Linux, Docker',
      url:               siteUrl,
      license:           'MIT (client SDK) + BSL 1.1 (server)',
      offers: [
        { '@type': 'Offer', name: 'Community', price: '0',    priceCurrency: 'USD' },
        { '@type': 'Offer', name: 'Starter',   price: '149',  priceCurrency: 'USD', priceSpecification: { '@type': 'UnitPriceSpecification', unitCode: 'MON' } },
        { '@type': 'Offer', name: 'Business',  price: '599',  priceCurrency: 'USD', priceSpecification: { '@type': 'UnitPriceSpecification', unitCode: 'MON' } },
      ],
    })} />
  </head>
  <body>
    <slot />

    {/* Scroll-reveal observer — promotes .revealed on elements entering viewport */}
    <script is:inline>
      (function () {
        if (!document.documentElement.classList.contains('js-reveal')) return
        const targets = document.querySelectorAll('section .grid > *, section details, section > div > article')
        const obs = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed')
              observer.unobserve(entry.target)
            }
          })
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' })
        targets.forEach((el) => obs.observe(el))
      })()
    </script>
  </body>
</html>
