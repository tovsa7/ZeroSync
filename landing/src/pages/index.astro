---
import Base         from '../layouts/Base.astro'
import Hero         from '../components/Hero.astro'
import Why          from '../components/Why.astro'
import UseCases     from '../components/UseCases.astro'
import QuickStart   from '../components/QuickStart.astro'
import HowItWorks   from '../components/HowItWorks.astro'
import Comparison   from '../components/Comparison.astro'
import FAQ          from '../components/FAQ.astro'
import ForCompanies from '../components/ForCompanies.astro'
import Footer       from '../components/Footer.astro'

// Pricing component is intentionally not rendered during the Apache 2.0
// open-core transition. The signaling server is now Apache 2.0; the paid
// enterprise plugin (admin dashboard, SSO, audit log) is in development.
// Re-introduce <Pricing /> once the plugin and tier definitions are real.
---

<Base>
  <main>
    <Hero />
    <Why />
    <UseCases />
    <QuickStart />
    <HowItWorks />
    <Comparison />
    <FAQ />
    <ForCompanies />
  </main>
  <Footer />
</Base>
