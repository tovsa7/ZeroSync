---
import Base         from '../layouts/Base.astro'
import Hero         from '../components/Hero.astro'
import Why          from '../components/Why.astro'
import UseCases     from '../components/UseCases.astro'
import QuickStart   from '../components/QuickStart.astro'
import HowItWorks   from '../components/HowItWorks.astro'
import Comparison   from '../components/Comparison.astro'
import FAQ          from '../components/FAQ.astro'
import ForCompanies from '../components/ForCompanies.astro'
import Footer       from '../components/Footer.astro'

// No pricing section on the page during the Apache 2.0 open-core transition.
// The signaling server is Apache 2.0 (free, forever); the paid enterprise
// plugin (admin dashboard, SSO, audit log, compliance reports) is in
// development. Pricing strategy lives in the private vault — a Pricing
// component will be written from scratch when the plugin ships and tier
// numbers are locked from design-partner conversations.
---

<Base>
  <main>
    <Hero />
    <Why />
    <UseCases />
    <QuickStart />
    <HowItWorks />
    <Comparison />
    <FAQ />
    <ForCompanies />
  </main>
  <Footer />
</Base>
