# ZeroSync — environment variables
# Copy to .env and fill in your values before running docker compose up.

# ── Required ──────────────────────────────────────────────────────────────────

# Your domain. Caddy will obtain a TLS certificate from Let's Encrypt.
ZEROSYNC_DOMAIN=sync.example.com

# ── License (optional) ────────────────────────────────────────────────────────

# Leave empty to run on the Community tier — no enforced room or peer limits,
# intended for non-production use (development, OSS, evaluation). Production
# deployments should hold a paid tier license. See pricing on the website or
# contact contact.zerosync@proton.me to obtain a license key.
ZEROSYNC_LICENSE_KEY=
ZEROSYNC_LICENSE_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────

# Number of OS threads for the signaling server (default: 2).
GOMAXPROCS=2

# ── Encrypted relay (optional) ────────────────────────────────────────────────

# The encrypted relay node is shipped as ghcr.io/tovsa7/zerosync-relay. To
# run it, add a service to docker-compose.yml with the same SIGNALING_URL
# and one ROOM_ID per room you want covered. The relay forwards opaque
# ciphertext only — it has no roomKey and cannot decrypt anything.
